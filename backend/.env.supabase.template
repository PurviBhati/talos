# Copy to backend/.env (or merge into your existing .env).
# Restart backend after changes. Python summarizer loads backend/.env too.

# ─── Supabase (required for DB + Storage + dashboard settings) ─────────────
# Dashboard: Project Settings → API (URL + service_role secret)
# Database:  Project Settings → Database → Connection string → URI → Pooler (transaction mode, port 6543)

SUPABASE_URL=https://<project-ref>.supabase.co
# Use service_role key (server only). Never expose in frontend.
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_BUCKET=talos

# Primary connection for Node (pg) and Python (psycopg). Prefer pooler on 6543.
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password-url-encoded>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Optional legacy name; leave empty if SUPABASE_DB_URL is set.
DATABASE_URL=

# Block accidental localhost Postgres in prod (keep false when using Supabase).
ALLOW_LOCAL_DB=false

# ─── Postgres pool / retries (optional — defaults work for Supabase pooler) ──
# PG_QUERY_RETRIES=6
# PG_RETRY_BASE_DELAY_MS=400
# PG_RETRY_MAX_DELAY_MS=8000
# PG_IDLE_TIMEOUT_MS=20000
# PG_CONNECTION_TIMEOUT_MS=20000
# PG_MAX_USES=2000
# PG_POOL_ERROR_LOG_COOLDOWN_MS=60000
# PG_VERBOSE_RETRY_LOG=0

# ─── OpenAI (API — summarization + agent features) ───────────────────────────
OPENAI_API_KEY=<sk-...>
# Optional overrides:
# OPENAI_MODEL=gpt-4o
# OPENAI_SUMMARY_MODELS=gpt-4o (python-service; comma-separated fallbacks)

# ─── Public URL for webhooks / Teams (API surface) ───────────────────────────
# Graph change notifications and external callbacks must reach your server.
# NGROK_URL=https://xxxx.ngrok-free.app
# WEBHOOK_SECRET=<random-string-matching-azure-subscription-clientState>

# ─── Frontend → Backend API base (optional) ────────────────────────────────
# If unset, browser uses same hostname as the Next app on port 5000.
# NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── Python service (calls Node HTTP APIs; same machine default) ─────────────
# NODE_URL=http://localhost:5000
