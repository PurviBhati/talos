PORT=5000

# Core AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_SUMMARY_MODELS=gpt-4o
OPENAI_SUMMARY_MAX_TOKENS=1200

# Microsoft / Teams
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
MicrosoftAppId=
MicrosoftAppPassword=
TEAMS_FORWARD_TEAM_ID=
MONITORED_CHAT_IDS=

# Webhook/Tunnel
NGROK_URL=
WEBHOOK_SECRET=unifiedhub-secret-123

# Twilio WhatsApp (if using Twilio route)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
DEFAULT_WHATSAPP_NUMBER=
DEFAULT_COUNTRY_CODE=+91

# Slack
SLACK_BOT_TOKEN=

# Supabase / Postgres
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=talos
SUPABASE_DB_URL=
DATABASE_URL=
ALLOW_LOCAL_DB=false

# App behavior
BOT_TYPE=SingleTenant
TZ=Asia/Kolkata
SLACK_BATCH_SCANNER_ENABLED=true
RETRY_FORWARDS_ENABLED=true
WHATSAPP_BOT_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Optional tenancy defaults
DEFAULT_TENANT_ID=tenant-default
DEFAULT_TENANT_NAME=Default Tenant
DEFAULT_TENANT_SLUG=default

# Optional map for Twilio group JIDs to names
WHATSAPP_GROUP_JID_MAP={}
